# acquire-gov — environment template
# Copy to .env and fill in real values. .env is git-ignored.

# --- Auth / JWT ---
JWT_ISSUER_URI=http://localhost:8090/auth
JWT_AUDIENCE=acquire-gov

# --- Datastores ---
POSTGRES_URL=jdbc:postgresql://localhost:5432/acquire_gov
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password

MONGO_URL=mongodb://app:app_dev_password@localhost:27017
MONGO_DB=acquire_gov

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
# Pick ONE auth path:
#  (A) Bedrock API key (recommended) — single bearer token w/ built-in expiry.
#      Generate: Bedrock console > API keys > Generate (set expiry). Needs
#      boto3 >= 1.39.11; auto-used by boto3, no code change.
AWS_BEARER_TOKEN_BEDROCK=
#  (B) Long-lived IAM access key/secret (works with any boto3, weaker hygiene).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# ⚠ pinned a generation behind current GA on purpose (cohort updates this).
BEDROCK_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0

# --- Inter-service ---
API_GATEWAY_URL=http://localhost:8080
SOLICITATION_SERVICE_URL=http://localhost:8081
EVALUATION_SERVICE_URL=http://localhost:8082
AI_ORCHESTRATOR_URL=http://localhost:8000
